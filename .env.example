# HAANA – Umgebungsvariablen
# Kopiere diese Datei nach .env und fülle die Werte aus.
# Die .env-Datei wird NICHT ins Git eingecheckt.

# ── Authentifizierung ─────────────────────────────────────────────────────────
# Der Agent läuft über das Claude Agent SDK (claude_agent_sdk).
# Auth läuft über die gebundelte Claude Code CLI:
#   Option 1 (empfohlen): Claude.ai Subscription – kein API-Key nötig.
#                         CLI einmalig authentifizieren: claude auth login
#   Option 2: Anthropic API-Key als CLI-Variable setzen:
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Agent-Konfiguration ───────────────────────────────────────────────────────
# Welche Instanz läuft in diesem Container (alice | bob | ha-assist | ha-advanced)
HAANA_INSTANCE=alice
# Modell für den Agenten (leer = CLI-Default je nach Subscription/Konfiguration)
# HAANA_MODEL=claude-sonnet-4-6

# ── Ollama (lokale Modelle + Memory-LLM + Embeddings) ─────────────────────────
# Pflicht für Memory-Features (Memory-Extraktion + Embeddings über Ollama).
# Benötigte Modelle: qwen2.5:1.5b (Memory-LLM), bge-m3 (Embeddings)
# OLLAMA_URL=http://192.168.1.50:11434
# Modell für Memory-Extraktion (Standard: ministral-3-32k:3b)
# HAANA_MEMORY_MODEL=ministral-3-32k:3b

# ── Qdrant ────────────────────────────────────────────────────────────────────
# In Docker (Produktiv):  http://qdrant:6333  (Docker-Service-Name)
# Lokal / Entwicklung:    http://localhost:6333
QDRANT_URL=http://qdrant:6333

# ── Home Assistant ────────────────────────────────────────────────────────────
# HA_URL=http://homeassistant.local:8123
# HA_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# MCP-Server URL (ha-mcp Add-on – privater Pfad als Auth-Token, kein extra Header nötig)
# HA_MCP_URL=http://10.83.1.1:9583/private_XXXXXXXXXXXXXXXXXXXX

# ── WhatsApp Bridge ───────────────────────────────────────────────────────────
# Alices WhatsApp-JID (Format: 49XXXXXXXXXX@s.whatsapp.net, ohne führendes +)
# Optional – nur für Logging / Validierung beim Start
# BRIDGE_OWNER_JID=49XXXXXXXXXX@s.whatsapp.net
# BRIDGE_LOG_LEVEL=info

# ── Erweitert ─────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
